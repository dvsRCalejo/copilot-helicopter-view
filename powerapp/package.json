{
  "name": "vite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "code:bootstrap": "node ./scripts/bootstrapPowerConfig.mjs",
    "validate:power-config": "node ./scripts/validatePowerConfig.mjs",
    "code:list": "power-apps list-codeapps",
    "code:init": "power-apps init",
    "code:reset-auth": "node ./scripts/resetPowerAppsAuthCache.mjs",
    "code:push": "npm run validate:power-config && power-apps push"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@microsoft/power-apps": "^1.0.17",
    "@tanstack/react-query": "^5.96.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@microsoft/power-apps-cli": "0.9.1",
    "@microsoft/power-apps-vite": "^1.0.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^2.1.9"
  }
}
